exports[`Mocha config > createMochaConfig() > should return a config array when Mocha is not installed 1`] = `
[
  {
    "name": "uphold/mocha"
  }
]
`;

exports[`Mocha config > createMochaConfig() > should return full plugin config when both Mocha and plugin are installed 1`] = `
[
  {
    "name": "uphold/mocha > mocha/recommended",
    "rules": {
      "mocha/no-exclusive-tests": "error"
    }
  },
  {
    "name": "uphold/mocha",
    "rules": {
      "mocha/no-exclusive-tests": "error",
      "mocha/no-identical-title": "error",
      "mocha/no-nested-tests": "error",
      "mocha/no-sibling-hooks": "error"
    }
  }
]
`;

exports[`Mocha config > createMochaConfig() > should return globals config when Mocha is installed but plugin is not 1`] = `
