{
  "compilerOptions": {
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "skipLibCheck": false,
    "strict": true
  },
  "exclude": ["node_modules"],
  "typeAcquisition": {
    "enable": true
  }
}
